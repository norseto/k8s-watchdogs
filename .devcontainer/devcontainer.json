// For format details, see https://aka.ms/vscode-remote/devcontainer.json or the definition README at
// https://github.com/microsoft/vscode-dev-containers/tree/master/containers/go
{
  "name": "k8s-watchdogs",
  "image": "mcr.microsoft.com/devcontainers/base:noble",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--security-opt=seccomp=unconfined",
    "--cap-drop=ALL",
    "--cap-add=CHOWN",
    "--cap-add=FOWNER",
    "--cap-add=FSETID",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=AUDIT_WRITE",
    "--cap-add=KILL",
    "--cap-add=NET_BIND_SERVICE",
    "--cap-add=NET_RAW",
    "--cap-add=SETFCAP",
    "--cap-add=SETPCAP",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--cap-add=SYS_CHROOT",
    "--pids-limit=512",
    "--init"
  ],
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.25.9"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/mpriscella/features/kind:1": {},
    "ghcr.io/rio/features/skaffold:2": {},
    "ghcr.io/rio/features/kustomize:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {"moby": false}
  },
  // Use 'settings' to set *default* container specific settings.json values on container create.
  // You can edit these settings after create using File > Preferences > Settings > Remote.
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "go.gopath": "/go",
        "go.goroot": "/usr/local/go"
      }
    }
  },

  "remoteUser": "vscode",
  "containerEnv": {
    "CURSOR_API_KEY": "${localEnv:CURSOR_API_KEY}",
    "CONTEXT7_API_KEY": "${localEnv:CONTEXT7_API_KEY}",
    "GOCACHE": "/home/vscode/.gocache",
    "GOMODCACHE": "/home/vscode/.gomodcache",
    "GOPATH": "/go",
    "GOROOT": "/usr/local/go"
  },

  "postCreateCommand": ". .devcontainer/post-create.sh",

  "workspaceMount": "type=bind,source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename}",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  // Uncomment the next line if you want to publish any ports.
  // "appPort": [],
  // Uncomment the next line to run commands after the container is created.
  // "postCreateCommand": "go version",
  // Add the IDs of extensions you want installed when the container is created in the array below.
  "mounts": [
    "type=volume,consistency=delegated,source=vscode-aws-cred,target=/home/vscode/.aws",
    "type=volume,consistency=delegated,source=vscode-oci-k8s-cred,target=/home/vscode/.kube",
    "type=volume,consistency=delegated,source=vscode-go-path-pkg,target=/go/pkg",
    "type=volume,consistency=delegated,source=vscode-go-cache,target=/home/vscode/.gocache",
    "type=volume,consistency=delegated,source=vscode-go-modcache,target=/home/vscode/.gomodcache",
    "type=volume,source=codex-volume,target=/home/vscode/.codex,consistency=cached",
    "type=volume,source=claude-code,target=/home/vscode/.claude,consistency=cached",
    "source=copilot-volume,target=/home/vscode/.copilot,type=volume,consistency=cached",
    "source=cursor-volume,target=/home/vscode/.cursor,type=volume,consistency=cached"
  ]
}
